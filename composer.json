{
    "name": "madad/laravel-sdk",
    "description": "Official Laravel SDK for the Madad Partner Product API (v1).",
    "type": "library",
    "license": "MIT",
    "keywords": ["madad", "laravel", "sdk", "products", "sync"],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/bus": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "autoload": {
        "psr-4": {
            "Madad\\Sdk\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Madad\\Sdk\\MadadServiceProvider"
            ],
            "aliases": {
                "Madad": "Madad\\Sdk\\Facades\\Madad"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
