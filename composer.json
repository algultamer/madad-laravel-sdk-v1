{
    "name": "madad/laravel-sdk",
    "description": "Official Laravel SDK for the Madad Partner Product API (v1).",
    "type": "library",
    "license": "MIT",
    "keywords": ["madad", "laravel", "sdk", "products", "sync"],
    "homepage": "https://github.com/algultamer/madad-laravel-sdk-v1",
    "authors": [
        { "name": "Madad", "homepage": "https://madad-app.com" }
    ],
    "support": {
        "issues": "https://github.com/algultamer/madad-laravel-sdk-v1/issues",
        "source": "https://github.com/algultamer/madad-laravel-sdk-v1"
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/bus": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Madad\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Madad\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Madad\\Sdk\\MadadServiceProvider"
            ],
            "aliases": {
                "Madad": "Madad\\Sdk\\Facades\\Madad"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
